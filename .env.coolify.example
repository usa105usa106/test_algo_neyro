# Required
TELEGRAM_BOT_TOKEN=PUT_TELEGRAM_BOT_TOKEN_HERE
ADMIN_TELEGRAM_ID=PUT_YOUR_TELEGRAM_USER_ID_HERE

# Optional
DATA_ROOT=./storage
TELEGRAM_SEND_LIMIT_MB=48
DAYS_BACK=30
BASE_INTERVAL=1m
MEXC_BASE_URL=https://api.mexc.com
MIN_COVERAGE_RATIO=0.80

# Optional local-development override. Coolify v62 generates a stable key automatically.
SECRET_ENCRYPTION_KEY=

# Minimum available history accepted when a newly-listed symbol has less than DAYS_BACK candles.
MIN_EFFECTIVE_DAYS=20

# Intraday mode
INTRADAY_SCAN_INTERVAL_SEC=300
INTRADAY_DAYS_BACK=30

# Gmail OAuth credentials are entered through the Telegram button; no variables are required here.
