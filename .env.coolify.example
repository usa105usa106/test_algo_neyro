# Put these in Coolify -> Environment Variables.
TELEGRAM_BOT_TOKEN=123456:telegram_bot_token_here
ADMIN_TELEGRAM_ID=123456789

# Defaults are already correct for our research archive.
SYMBOLS=BTCUSDT,ETHUSDT
DAYS_BACK=365
BASE_INTERVAL=1m
MEXC_BASE_URL=https://api.mexc.com
DATA_ROOT=/app/storage
TELEGRAM_SEND_LIMIT_MB=48
TZ=UTC

# Optional. Leave empty and the bot creates its own Fernet key inside persistent storage.
# To keep encrypted API state decryptable across full storage migration, generate once:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=
