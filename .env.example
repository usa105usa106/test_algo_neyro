# Telegram
TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
ADMIN_TELEGRAM_ID=PASTE_YOUR_TELEGRAM_NUMERIC_ID_HERE

# Bot storage
DATA_ROOT=./storage

# Telegram standard Bot API upload is ~50 MB. Keep 47-49 MB for safety.
TELEGRAM_SEND_LIMIT_MB=48

# Data settings
SYMBOLS=BTCUSDT,ETHUSDT
DAYS_BACK=365
BASE_INTERVAL=1m

# MEXC public spot API
MEXC_BASE_URL=https://api.mexc.com

# Optional: if empty, bot creates storage/state/fernet.key on first API save.
SECRET_ENCRYPTION_KEY=
